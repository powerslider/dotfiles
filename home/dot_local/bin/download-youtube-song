#!/usr/bin/env bash
# vim: set sw=4 sts=4 et foldmethod=indent :
#
# Download audio from a YouTube URL into $YT_DL_DIR (defaults to
# ~/Dropbox/music if it exists, otherwise the current directory).

set -euo pipefail

if [[ -z "${YT_DL_DIR:-}" ]]; then
    if [[ -d "$HOME/Dropbox/music" ]]; then
        YT_DL_DIR="$HOME/Dropbox/music"
    else
        YT_DL_DIR="$PWD"
    fi
fi

cd "$YT_DL_DIR"
yt-dlp --extract-audio -o '%(title)s.%(ext)s' "$@"
