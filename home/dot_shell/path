# vim: set ft=sh :
#
# PATH setup. Sourced from ~/.zshenv for every shell.
#
# Runtime managers (Node, Python, Java, Go versions, etc.) are handled
# by mise, activated from ~/.zshrc. This file only sets up base PATH
# entries that should exist for non-interactive shells as well.

# Homebrew prefix + completions
eval "$(/opt/homebrew/bin/brew shellenv)"

# User-scoped bins (prepend so they win over system)
[[ -d "$HOME/bin" ]]        && PATH="$HOME/bin:$PATH"
[[ -d "$HOME/.local/bin" ]] && PATH="$HOME/.local/bin:$PATH"

# Go install target
[[ -n "$GOPATH" && -d "$GOPATH/bin" ]] && PATH="$PATH:$GOPATH/bin"

# Cargo (Rust toolchain has its own envar+source pattern)
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# pnpm — prepend only if not already there
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) [[ -d "$PNPM_HOME" ]] && PATH="$PNPM_HOME:$PATH" ;;
esac

# Prefer GNU grep over BSD grep
if [[ -d "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/grep/libexec/gnubin" ]]; then
    PATH="${HOMEBREW_PREFIX:-/opt/homebrew}/opt/grep/libexec/gnubin:$PATH"
fi

export PATH
