pls() {
    echo "$(pwd)/$1"
}

# Reload Ghostty's config without leaving the shell — sends Cmd+Shift+,
# via System Events. Requires Ghostty running + Accessibility permission.
ghostty-reload() {
    osascript \
        -e 'tell application "Ghostty" to activate' \
        -e 'tell application "System Events" to keystroke "," using {command down, shift down}'
}
