# vim: set ft=sh :
#
# Environment variables only. PATH manipulation lives in ~/.shell/path.
# Per-project overrides go in .envrc (direnv) or .mise.toml.

export EDITOR=nvim
export GIT_EDITOR=nvim
export PAGER=less
export GIT_PAGER=less
export TERMINAL=ghostty

export GOPATH="$HOME/go"

export DOCKER_DEFAULT_PLATFORM=linux/amd64
export GPG_TTY=$(tty)

# Serena's first start spins up language servers and can exceed Claude
# Code's default MCP startup timeout. 60s gives it room.
export MCP_TIMEOUT=60000
