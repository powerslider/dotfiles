# vim: set ft=sh :

alias rm='rm -i'
alias mv='mv -i'

# Route `vim` to neovim, and suppress ^S/^Q flow control each call
alias vim="stty stop '' -ixoff ; nvim"
alias vi='nvim'
ttyctl -f

alias k='kubectl'

# zoxide remapped to `j` (and ji/ja/jr/…) — but reclaim `jq` for the
# JSON tool, since zoxide also defines a `jq` query subcommand.
alias jq='command jq'

# Prefer GNU variants when the BSD defaults differ in flags
alias readlink=greadlink
alias tar=gtar

# Modern CLI replacements (only when installed, fall back silently)
command -v eza >/dev/null && { alias ll='eza -lah --git'; alias la='eza -lah --git'; alias lt='eza --tree --git-ignore'; }
command -v bat >/dev/null && alias batp='bat --paging=always'
