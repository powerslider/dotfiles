// Zed settings.
//
// Strategy: Cursor-style base keymap + edit predictions, Gruvbox theme,
// FiraCode Nerd Font everywhere, AI/agent docked right, language-aware
// format-on-save and inlay hints for Go + Rust.
//
// Docs: https://zed.dev/docs/configuring-zed
{
  // ===== Identity / privacy =====
  "telemetry": { "diagnostics": false, "metrics": false },

  // ===== Theme + icons =====
  "base_keymap": "Cursor",
  "icon_theme": "Catppuccin Mocha",
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark"
  },

  // ===== Fonts =====
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 14,
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", ".SystemUIFont"],
  "ui_font_size": 14,
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "font_size": 13,
    "shell": "system",
    "working_directory": "current_project_directory",
    "blinking": "off",
    "copy_on_select": true
  },

  // ===== Editor behaviour =====
  "show_edit_predictions": true,
  "edit_predictions": { "mode": "subtle" },
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "use_autoclose": true,
  "tab_size": 4,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "wrap_guides": [100],
  "show_whitespaces": "selection",
  "show_wrap_guides": true,
  "cursor_blink": true,
  "current_line_highlight": "gutter",
  "scroll_beyond_last_line": "one_page",
  "selection_highlight": true,
  "middle_click_paste": false,

  "gutter": { "code_actions": true, "runnables": true, "folds": true, "line_numbers": true },

  // Inline diagnostics — error/warning text shown next to the line,
  // not just in the gutter. The single biggest readability upgrade.
  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": "warning",
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0
    }
  },

  // Sticky scroll — keep the enclosing scope header pinned as you scroll.
  "sticky_scroll": { "enabled": true },

  // Vim mode is OFF by default. Flip to true if you want a proper
  // jump list (Ctrl-O / Ctrl-I), marks, and motions — but every binding
  // we've added is non-vim-mode so this will change your muscle memory.
  "vim_mode": false,

  // Vim-style relative line numbers in the gutter — distances visible
  // at a glance even without vim mode.
  "relative_line_numbers": true,

  // Tab close returns to previously-active tab (browser semantics)
  // rather than the geometrically adjacent one.
  // (defined inside the `tabs` block below)

  // Extensions that should always be present — auto-install on launch.
  "auto_install_extensions": {
    "gruvbox": true,
    "catppuccin-icons": true,
    "html": true,
    "dockerfile": true,
    "make": true,
    "nu": true,
    "snippets": true
  },

  // Project-wide / global search default — case-insensitive (no
  // "smart-case" option in Zed; this matches everywhere by default
  // and you can toggle per-search).
  "search": {
    "case_sensitive": false,
    "whole_word": false,
    "regex": false
  },

  // ===== Visual chrome =====
  "scrollbar": {
    "show": "auto",
    "diagnostics": "all",
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "cursors": true
  },
  "minimap": { "show": "auto", "thumb": "always", "current_line_highlight": "line" },
  "indent_guides": { "enabled": true, "coloring": "indent_aware" },
  "tab_bar": { "show_nav_history_buttons": false, "show_tab_bar_buttons": false },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_close_button": "hover",
    "show_diagnostics": "errors",
    "activate_on_close": "history"
  },
  "centered_layout": { "left_padding": 0.15, "right_padding": 0.15 },

  // ===== Inlay hints =====
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },

  // ===== Git =====
  "git": {
    "inline_blame": { "enabled": true, "delay_ms": 500, "show_commit_summary": true },
    "git_gutter": "tracked_files",
    "hunk_style": "staged_hollow"
  },
  "diff_view_style": "unified",

  // ===== Panels / docks =====
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
    "git_status": true,
    "indent_size": 16,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "show_diagnostics": "all",
    "default_width": 280
  },
  "outline_panel": {
    "dock": "left",
    "auto_reveal_entries": true,
    "auto_fold_dirs": true
  },
  "collaboration_panel": { "dock": "left" },
  "git_panel": { "dock": "left" },
  "agent": {
    "dock": "right",
    "version": "2",
    "default_model": { "provider": "anthropic", "model": "claude-sonnet-4-6" },
    "default_view": "thread",
    "always_allow_tool_actions": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": { "mode": ["bypassPermissions"] },
      "type": "registry"
    },
    "codex-acp": { "type": "registry" }
  },

  // ===== Session =====
  "session": { "trust_all_worktrees": true },
  "restore_on_startup": "last_workspace",

  // ===== File-finder + search niceties =====
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/.next",
    "**/dist",
    "**/build",
    "**/target",
    "**/vendor"
  ],

  // ===== Language-specific =====
  "languages": {
    "Go": {
      "language_servers": ["gopls", "..."],
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true
      },
      "preferred_line_length": 120,
      "extend_comment_on_newline": true,
      "colorize_brackets": true
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "tab_size": 4,
      "format_on_save": "on",
      "code_actions_on_format": { "source.fixAll": true },
      "preferred_line_length": 100,
      "extend_comment_on_newline": true,
      "colorize_brackets": true
    },
    "TOML": { "format_on_save": "on" },
    "JSON": { "tab_size": 2, "format_on_save": "on" },
    "JSONC": { "tab_size": 2 },
    "YAML": { "tab_size": 2, "preferred_line_length": 120 },
    "Markdown": {
      "format_on_save": "off",
      "show_edit_predictions": false,
      "soft_wrap": "editor_width"
    },
    "Plain Text": { "show_edit_predictions": false }
  },

  // ===== LSP =====
  "lsp": {
    "gopls": {
      "initialization_options": {
        "usePlaceholders": true,
        "completeUnimported": true,
        "staticcheck": true,
        "gofumpt": true,
        "semanticTokens": true,
        "experimentalPostfixCompletions": true,
        "analyses": {
          "fieldalignment": true,
          "ifaceassert": true,
          "loopclosure": true,
          "nilness": true,
          "shadow": true,
          "stringintconv": true,
          "unmarshal": true,
          "unreachable": true,
          "unusedparams": true,
          "unusedwrite": true,
          "useany": true
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": { "command": "clippy", "extraArgs": ["--all-targets", "--all-features"] },
        "cargo": {
          "buildScripts": { "enable": true },
          "features": "all"
        },
        "procMacro": { "enable": true },
        "inlayHints": {
          "lifetimeElisionHints": { "enable": "skip_trivial" },
          "typeHints": { "enable": true },
          "parameterHints": { "enable": true },
          "chainingHints": { "enable": true },
          "closureReturnTypeHints": { "enable": "with_block" },
          "reborrowHints": { "enable": "mutable" }
        },
        "completion": { "fullFunctionSignatures": { "enable": true } }
      }
    }
  }
}
