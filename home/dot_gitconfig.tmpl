[user]
    name = {{ .full_name }}
    email = {{ .personal_email }}
{{- if .signing_key }}
    signingkey = {{ .signing_key }}
{{- end }}

{{ if .work_email -}}
[includeIf "gitdir:~/git-repos/work/"]
    path = ~/.gitconfig-work

[includeIf "gitdir:~/work/"]
    path = ~/.gitconfig-work
{{- end }}

[init]
    defaultBranch = main

[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    syntax-theme = gruvbox-dark

[merge]
    conflictStyle = zdiff3

[diff]
    colorMoved = default

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true

[rerere]
    enabled = true

[commit]
    # Show the staged diff under the commit message editor for context.
    verbose = true

[rebase]
    autosquash = true
    autostash = true

{{- if .signing_key }}
[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers

[commit]
    gpgsign = true

[tag]
    gpgsign = true
{{ end }}
[credential]
    helper = osxkeychain

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    sw = switch
    br = branch
    ci = commit
    last = log -1 HEAD --stat
    lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
    unstage = reset HEAD --
    amend = commit --amend --no-edit
    pushf = push --force-with-lease
    cleanup = !git branch --merged | grep -vE '^\\*|main|master|develop' | xargs -n 1 git branch -d
